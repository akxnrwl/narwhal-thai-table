# Narwhal Thai Table — environment variables
# Copy to .env.local for local dev, OR set these in Netlify:
#   Site settings -> Environment variables -> Add a variable. Then redeploy.
# Put REAL values only in .env.local / Netlify — never commit real secrets.

# ---- Owner login (Control Room, /stats, /cal, all /api/agents/*, /api/toast/*) ----
STATS_TOKEN=change-me-owner-password         # the owner password you type to log in
AUTH_SECRET=change-me-long-random-string     # signs the owner session cookie (any long random string)

# ---- AI agents: Insights / Reviewer / Social / Planner ----
# Same key Aileen uses. With this set, agents give REAL Claude output NOW (on demo data).
ANTHROPIC_API_KEY=sk-ant-...

# ---- Toast POS — THE SWITCH ----
# Leave these BLANK until Toast is ready. The moment all four are set + you redeploy,
# every agent + the AI Office flips from demo to REAL restaurant data. No code change.
# Get them in Toast Web -> Integrations -> Toast API access (needs RMS Essentials or higher).
TOAST_HOSTNAME=ws-api.toasttab.com           # production Toast API host (leave as-is)
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
TOAST_RESTAURANT_GUID=                        # your restaurant's external GUID
